*.py[cod]
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# 文档（生产镜像不需要）
README.md
PRD.md
task.md
planning.md
DEPLOYMENT.md
PROJECT_CONTEXT.md
PROJECT_DEPLOY_STATUS.md
docs/

# Docker
docker/.env
docker/backup.sh
docker/deploy.sh
docker/ssl-renew.sh
