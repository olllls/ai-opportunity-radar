# =============================================================================
# AI机会雷达 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# =============================================================================

# ----- LLM API 配置（至少配置一个） -----

# DeepSeek API（推荐，性价比最高）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 通义千问 API（可选）
# TONGYI_API_KEY=your-tongyi-api-key
# TONGYI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# TONGYI_MODEL=qwen-plus

# 智谱 GLM API（可选）
# GLM_API_KEY=your-glm-api-key
# GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4-plus

# OpenAI API（可选，国内访问受限）
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# 默认 LLM 提供商：deepseek / tongyi / glm / openai
LLM_PROVIDER=deepseek

# ----- 数据库配置 -----

# SQLite（MVP）
DATABASE_URL=sqlite+aiosqlite:///./data/database.db

# PostgreSQL（后续生产环境）
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_daily

# ----- 推送配置（可选，至少配一个才能收到推送） -----

# 企业微信机器人 Webhook（推荐）
# 在企微群中添加机器人，复制 Webhook URL
WECHAT_WEBHOOK_URL=

# 邮件推送（SMTP）
# 以 QQ 邮箱为例：需开启 SMTP 服务，使用授权码
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_TO=

# ----- 应用设置 -----

SITE_NAME=AI机会雷达
SITE_URL=http://localhost:8000

# ----- 定时任务时间配置（可选，有默认值） -----

# 采集窗口（06:00-23:00）
COLLECT_START_TIME=06:00
COLLECT_END_TIME=23:00

# 日报生成时间
REPORT_GENERATE_TIME=07:30

# 推送时间
PUSH_TIME=08:00

# ----- 调试与日志 -----

LOG_LEVEL=INFO
DEBUG=false
